# Polymarket AI Team - Backend

# LLM / OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here
LLM_MODEL=stepfun/step-3.5-flash:free

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/polymarket_ai

# Redis
REDIS_URL=redis://localhost:6379/0

# Trading
STARTING_CAPITAL=500.0
MAX_TRADE_SIZE=30.0
MAX_OPEN_TRADES=5
MIN_EDGE=0.08
EMERGENCY_BALANCE=350.0
STOP_BALANCE=300.0

# Scheduler
SCAN_INTERVAL_MINUTES=30
RESOLUTION_CHECK_INTERVAL_MINUTES=60

# App
DEBUG=false
LOG_LEVEL=INFO
